<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.cobra.detailedhealth" extension-version="1.0.0">
    <default-locale>en-US</default-locale>
    <name>COBRA Detailed Health Impacts</name>
    <description>Full health endpoint breakdown table with geographic and per-fuel views.</description>
    <author name="COBRA API" email="support@cobra-api.up.railway.app" website="https://cobra-api.up.railway.app"/>
    <min-api-version>1.8</min-api-version>
    <source-location>
      <url>https://cobra-api.up.railway.app/extension/detailed-health.html</url>
    </source-location>
    <icon></icon>
  </dashboard-extension>
</manifest>
